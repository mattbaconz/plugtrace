{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pluglabs.dev/schemas/plugtrace-report-1.0.0.json",
  "title": "PlugTrace Report 1.0.0",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "privacyDeclaration", "deployment", "baseline", "changes", "issues", "suspects", "verification", "incidents"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "generatedAt": {"type": "string", "format": "date-time"},
    "privacyMode": {"type": "string"},
    "privacyDeclaration": {
      "type": "object",
      "required": ["localFirst", "automaticUpload", "configValuesIncluded", "secretRedaction"],
      "properties": {
        "localFirst": {"const": true},
        "automaticUpload": {"const": false},
        "configValuesIncluded": {"const": false},
        "secretRedaction": {"type": "string"}
      },
      "additionalProperties": false
    },
    "scope": {"type": "object"},
    "platform": {"type": "object", "description": "Artifact and capability declaration; absence never implies support."},
    "release": {"type": "object"},
    "executiveSummary": {"type": "object"},
    "preview": {"type": "array", "items": {"type": "string"}},
    "redactionWarnings": {"type": "array", "items": {"type": "string"}},
    "deployment": {"type": "object"},
    "baseline": {"type": "object"},
    "changes": {"type": "array"},
    "issues": {"type": "array"},
    "suspects": {"type": "array"},
    "verification": {"type": ["object", "null"]},
    "incidents": {"type": "array"},
    "annotations": {"type": "array"},
    "spark": {"type": "object"}
  },
  "additionalProperties": true
}
